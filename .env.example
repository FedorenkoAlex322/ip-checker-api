APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ip_checker_api
DB_USERNAME=root
DB_PASSWORD=

# Docker environment (uncomment when using docker-compose)
# DB_HOST=mysql
# DB_PASSWORD=secret
# REDIS_HOST=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Rate Limiting
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=300
RATE_LIMIT_ENTERPRISE=1000

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIME=30

# Cache TTL (seconds)
CACHE_TTL_IP_LOOKUP=3600
CACHE_TTL_DOMAIN_LOOKUP=3600
CACHE_TTL_EMAIL_LOOKUP=3600

# Lookup Log Retention (days)
LOOKUP_LOG_RETENTION_DAYS=90

# Provider: Mock
PROVIDER_MOCK_ENABLED=true

# External API Providers
# AbuseIPDB — IP threat/reputation (https://abuseipdb.com, free: 1000 checks/day)
ABUSEIPDB_API_KEY=

# VirusTotal — IP + Domain threat intelligence (https://virustotal.com, free: 4 req/min, 500/day)
VIRUSTOTAL_API_KEY=

# ipinfo.io — IP geolocation (https://ipinfo.io, free: 50K/month, token optional)
IPINFO_TOKEN=

# EmailRep.io — Email reputation (https://emailrep.io, free: 100/day, key optional)
EMAILREP_API_KEY=

# ip-api.com — IP geolocation (http://ip-api.com, free: 45 req/min, no key needed)
# No API key required for free tier
